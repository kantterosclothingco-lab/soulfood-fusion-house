# Server
PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:3000
ADMIN_EXPORT_KEY=change-this-to-a-long-private-key

# Square
# Use sandbox while testing, then production when live.
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=replace-with-square-access-token
SQUARE_LOCATION_ID=replace-with-square-location-id
SQUARE_CURRENCY=AUD
SQUARE_VERSION=2026-01-22

# Must exactly match the Notification URL entered in Square Developer Console.
# Localhost cannot receive production Square webhooks; use a public deployed URL or ngrok for testing.
SQUARE_WEBHOOK_NOTIFICATION_URL=http://localhost:3000/api/square/webhook
SQUARE_WEBHOOK_SIGNATURE_KEY=replace-with-square-webhook-signature-key

# Optional
SUPPORT_EMAIL=
